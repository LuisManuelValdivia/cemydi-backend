DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
DATABASE_DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
JWT_SECRET="your_secret"
JWT_EXPIRES_IN="1d"
PORT=4000
CORS_ORIGIN="http://localhost:3000"
BACKEND_PUBLIC_URL="http://localhost:4000"
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="user@example.com"
SMTP_PASS="your_smtp_password"
MAIL_FROM="CEMYDI <no-reply@example.com>"
EMAIL_VERIFICATION_EXPIRES_MINUTES="60"
PASSWORD_RESET_EXPIRES_MINUTES="15"
PASSWORD_RESET_MAX_ATTEMPTS="5"
GOOGLE_DRIVE_PROVIDER="oauth2"
GOOGLE_DRIVE_FOLDER_ID="your_google_drive_folder_id"
GOOGLE_OAUTH_CLIENT_ID="your_google_oauth_client_id"
GOOGLE_OAUTH_CLIENT_SECRET="your_google_oauth_client_secret"
GOOGLE_OAUTH_REDIRECT_URI="http://127.0.0.1:3005/oauth2callback"
GOOGLE_OAUTH_REFRESH_TOKEN="your_google_oauth_refresh_token"
GOOGLE_DRIVE_CLIENT_EMAIL="your_service_account_email"
GOOGLE_DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key\n-----END PRIVATE KEY-----\n"
CLOUDINARY_URL="cloudinary://your_api_key:your_api_secret@your_cloud_name"
CLOUDINARY_PRODUCTS_FOLDER="cemydi/products"
